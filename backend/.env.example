# Copy this file to .env inside the backend/ folder before running uvicorn locally.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Optional: Gemini (better AI narrative text)
# https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

APP_NAME=AI Investment Research API
DEBUG=false

# Frontend origins allowed by CORS (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Database — pick ONE approach
# -----------------------------------------------------------------------------
# SQLite (default for local dev): relative path from backend/ working directory
DATABASE_PATH=data/app.db

# PostgreSQL: when set, SQLite path above is unused. Compose example:
#   postgresql://ai_app:YOUR_PASSWORD@localhost:5433/ai_investment
DATABASE_URL=

# -----------------------------------------------------------------------------
# Auth — JWT issued on /api/v1/auth/register and /api/v1/auth/login
# Use a long random string in production; not the literal "change-me".
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# PostgreSQL defaults (referenced by docker-compose and docs — local dev sample only)
# -----------------------------------------------------------------------------
POSTGRES_DB=ai_investment
POSTGRES_USER=ai_app
POSTGRES_PASSWORD=Cr7m10p7!!
POSTGRES_PORT=5433

# -----------------------------------------------------------------------------
# Redis (optional locally): caching for stock payloads. Backend tolerates Redis
# being unreachable (cache disables itself). Compose uses redis:6379.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
