JWT_EXPIRE_MINUTES=1440

# PostgreSQL (for migration/scale phase)
POSTGRES_DB=ai_investment
POSTGRES_USER=ai_app
POSTGRES_PASSWORD=Cr7m10p7!!
POSTGRES_PORT=5433

# Redis
REDIS_URL=redis://localhost:6379/0
